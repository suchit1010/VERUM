{
  "name": "basket-protocol",
  "version": "0.1.0",
  "scripts": {
    "dev":         "npm --prefix app run dev --",
    "app:build":   "npm --prefix app run build",
    "build":       "anchor build",
    "test":        "anchor test",
    "deploy":      "anchor deploy",
    "init":        "npx ts-node scripts/deploy.ts",
    "init-vaults": "npx ts-node scripts/init-vaults.ts",
    "app":         "cd app && npm run dev"
  },
  "dependencies": {
    "@coral-xyz/anchor":                "^0.30.0",
    "@solana/web3.js":                  "^1.95.0",
    "@solana/spl-token":                "^0.4.0",
    "@pythnetwork/hermes-client":        "^1.3.0"
  },
  "devDependencies": {
    "@types/node":       "^20.0.0",
    "typescript":        "^5.0.0",
    "ts-mocha":          "^10.0.0",
    "chai":              "^4.3.0",
    "@types/chai":       "^4.3.0",
    "@types/mocha":      "^10.0.0"
  }
}
